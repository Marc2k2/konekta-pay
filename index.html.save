<!DOCTYPE html>
<html lang="pt-PT">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  <!-- Content Security Policy — bloqueia XSS e recursos externos não autorizados -->
  <meta http-equiv="Content-Security-Policy" content="
    default-src 'self';
    script-src  'self' 'unsafe-inline' https://cdn.jsdelivr.net;
    style-src   'self' 'unsafe-inline' https://fonts.googleapis.com;
    font-src    'self' https://fonts.gstatic.com;
    img-src     'self' data: https:;
    connect-src 'self' https://*.supabase.co wss://*.supabase.co
                https://openexchangerates.org https://fonts.googleapis.com;
    frame-src   'none';
    object-src  'none';
    base-uri    'self';
  " />

  <meta name="theme-color" content="#0057FF" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Konekta Pay" />
  <meta name="description" content="O Seu Dinheiro, Sem Fronteiras — Pagamentos unificados na Guiné-Bissau" />
  <title>Konekta Pay</title>

  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="public/icon-192.png" />
  <link rel="icon" type="image/png" href="public/icon-192.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="css/tokens.css" />
  <link rel="stylesheet" href="css/layout.css" />
  <link rel="stylesheet" href="css/components.css" />
  <link rel="stylesheet" href="css/animations.css" />
  <link rel="stylesheet" href="css/exchange-parcel.css" />

  <style>
    /* btn-danger: botão destrutivo (vermelho) — usado no UI.confirm() */
    .btn-danger {
      background: var(--red-dim);
      border: 1px solid rgba(255,77,106,.35);
      border-radius: var(--r-lg);
      padding: 14px 20px;
      color: var(--red);
      font-weight: 700;
      font-size: 14px;
      font-family: var(--font);
      cursor: pointer;
      transition: all var(--tr-fast);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      line-height: 1;
    }
    .btn-danger:hover  { background: rgba(255,77,106,.2); }
    .btn-danger:active { transform: scale(.97); }
    /* w-full utilitário */
    .w-full { width: 100%; }
    /* font-mono shorthand */
    .font-mono { font-family: var(--font-mono, monospace); }
  </style>
</head>
<body>

  <!-- ═══ AUTH GATE ═══════════════════════════════════════════════════ -->
  <div id="auth-gate">
    <div class="auth-card">
      <div class="auth-logo">
        <div class="logo-mark">K</div>
        <div>
          <div class="logo-text">Konekta Pay</div>
          <div class="logo-sub">O Seu Dinheiro, Sem Fronteiras</div>
        </div>
      </div>

      <!-- LOGIN — campos todos visíveis de uma vez (UX fix) -->      <div id="auth-login">
        <h2 class="auth-title">Bem-vindo de volta</h2>
        <p class="auth-desc">Entra com o teu número e PIN</p>

        <div class="form-group">
          <label class="form-label" for="loginPhone">Nº de Telefone</label>
          <div class="phone-input-row">
            <div class="country-code">+245</div>
            <input class="form-input" type="tel" id="loginPhone"
                   placeholder="955 000 000" maxlength="11"
                   autocomplete="tel" inputmode="tel" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="loginPin">PIN de 6 Dígitos</label>
          <input class="form-input pin-input" type="password" id="loginPin"
                 placeholder="••••••" maxlength="6" inputmode="numeric"
                 autocomplete="current-password" />
        </div>

        <button class="btn-primary w-full" id="loginBtn">Entrar</button>
        <p class="auth-link">Não tens conta? <span id="goRegister">Criar conta</span></p>
      </div>

      <!-- REGISTO -->
      <div id="auth-register" style="display:none">
        <h2 class="auth-title">Criar Conta</h2>
        <p class="auth-desc">Junta-te ao Konekta Pay em segundos</p>

        <div class="form-group">
          <label class="form-label" for="regName">Nome Completo</label>
          <input class="form-input" type="text" id="regName"
                 placeholder="Ex: Mamadu Baldé" autocomplete="name" />
        </div>

        <div class="form-group">
          <label class="form-label" for="regPhone">Nº de Telefone</label>
          <div class="phone-input-row">
            <div class="country-code">+245</div>
            <input class="form-input" type="tel" id="regPhone"
                   placeholder="955 000 000" maxlength="11"
                   autocomplete="tel" inputmode="tel" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="regPin">Criar PIN (6 dígitos)</label>
          <input class="form-input pin-input" type="password" id="regPin"
                 placeholder="••••••" maxlength="6" inputmode="numeric"
                 autocomplete="new-password" />
        </div>

        <div class="form-group">
          <label class="form-label" for="regEmail">Email (opcional)</label>
          <input class="form-input" type="email" id="regEmail"
                 placeholder="exemplo@email.com" autocomplete="email" />
        </div>

        <button class="btn-primary w-full" id="regBtn">Criar Conta</button>
        <p class="auth-link">Já tens conta? <span id="goLogin">Entrar</span></p>
      </div>

      <div id="auth-error"   class="auth-error"   style="display:none"></div>
      <div id="auth-loading" class="auth-loading"  style="display:none">
        <div class="spinner"></div><span>A verificar…</span>
      </div>
    </div>
  </div>

  <!-- ═══ APP SHELL ════════════════════════════════════════════════════ -->
  <div id="app" style="display:none">
    <nav id="sidebar" aria-label="Navegação principal">
      <div class="sidebar-logo">
        <div class="logo-mark">K</div>
        <div>
          <div class="logo-text">Konekta Pay</div>
          <div class="logo-sub">v1.2.0</div>
        </div>
      </div>
      <div class="nav-item active" data-screen="home"     role="menuitem">🏠 Início</div>
      <div class="nav-item"        data-screen="pay"      role="menuitem">↗️ Pagamentos</div>
      <div class="nav-item"        data-screen="exchange" role="menuitem">💱 Câmbio</div>
      <div class="nav-item"        data-screen="parcel"   role="menuitem">📦 Encomendas</div>
      <div class="nav-item"        data-screen="card"     role="menuitem">💳 Cartão Virtual</div>
      <div class="nav-item"        data-screen="profile"  role="menuitem">👤 Perfil & Contas</div>
      <div class="sidebar-footer">
        <div class="pwa-status">
          <span class="pwa-dot"></span>
          <span id="pwaStatusText">PWA · Online</span>
        </div>
        <div class="version-tag">Konekta Pay · v1.2.0</div>
      </div>
    </nav>

    <div id="main">
      <div id="screen-home"     class="screen active"></div>
      <div id="screen-pay"      class="screen"></div>
      <div id="screen-exchange" class="screen"></div>
      <div id="screen-parcel"   class="screen"></div>
      <div id="screen-card"     class="screen"></div>
      <div id="screen-profile"  class="screen"></div>
    </div>
  </div>

  <!-- Bottom Nav (Mobile — 4 itens, alvos de toque ≥44px) -->
  <nav id="bottom-nav" style="display:none" aria-label="Navegação mobile">
    <div class="bnav-item active" data-screen="home">
      <div class="bnav-icon">🏠</div><div class="bnav-dot"></div><div class="bnav-label">Início</div>
    </div>
    <div class="bnav-item" data-screen="pay">
      <div class="bnav-icon">↗️</div><div class="bnav-dot"></div><div class="bnav-label">Pagar</div>
    </div>
    <div class="bnav-item" data-screen="exchange">
      <div class="bnav-icon">💱</div><div class="bnav-dot"></div><div class="bnav-label">Câmbio</div>
    </div>
    <div class="bnav-item" data-screen="profile">
      <div class="bnav-icon">👤</div><div class="bnav-dot"></div><div class="bnav-label">Perfil</div>
    </div>
  </nav>

  <div id="modal-root" role="region" aria-label="Modais"></div>
  <div id="toast" role="alert" aria-live="polite" aria-atomic="true">
    <span id="toast-msg"></span>
  </div>

  <!-- Supabase SDK -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>

  <!-- App modules (ordem importa) -->
  <script src="js/config.js"></script>
  <script src="js/db.js"></script>
  <script src="js/ui.js"></script>
  <script src="js/auth.js"></script>
  <script src="js/router.js"></script>
  <script src="js/ussd.js"></script>
  <script src="js/screens/home.js"></script>
  <script src="js/screens/pay.js"></script>
  <script src="js/screens/exchange.js"></script>
  <script src="js/screens/parcel.js"></script>
  <script src="js/screens/card.js"></script>
  <script src="js/screens/profile.js"></script>
  <script src="js/app.js"></script>

  <!-- Bootstrap: event listeners sem onclick inline -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Auth
      document.getElementById('loginBtn')  ?.addEventListener('click', () => Auth.handleLogin());
      document.getElementById('regBtn')    ?.addEventListener('click', () => Auth.handleRegister());
      document.getElementById('goRegister')?.addEventListener('click', () => Auth.showRegister());
      document.getElementById('goLogin')   ?.addEventListener('click', () => Auth.showLogin());

      // Enter key no PIN → submeter login
      document.getElementById('loginPin')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') Auth.handleLogin();
      });
      document.getElementById('loginPhone')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') document.getElementById('loginPin')?.focus();
      });
      document.getElementById('regPin')?.addEventListener('keydown', e => {
        if (e.key === 'Enter') Auth.handleRegister();
      });

      // Sidebar nav (event delegation — sem onclick inline)
      document.getElementById('sidebar')?.addEventListener('click', e => {
        const item = e.target.closest('.nav-item[data-screen]');
        if (item) Router.go(item.dataset.screen);
      });

      // Bottom nav
      document.getElementById('bottom-nav')?.addEventListener('click', e => {
        const item = e.target.closest('.bnav-item[data-screen]');
        if (item) Router.go(item.dataset.screen);
      });

      // ESC fecha modais
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape') UI.closeAllModals();
      });

      // Iniciar app
      Auth.init();
    });
  </script>
</body>
</html>
